<!DOCTYPE html>
<html lang="ja">
<head><meta charset="UTF-8"><title>ユーザー一覧</title></head>
<body>
  <h1>ユーザー一覧</h1>
  <ul>
    <% users.forEach(user => { %>
      <!-- 名前だけでなく、年齢（age）も表示するように変えたぞ -->
      <li><%= user.name %>（<%= user.age || '秘密' %> 歳）</li>
    <% }) %>
  </ul>
  <hr>
  <h2>ユーザー追加</h2>
  <form action="/users" method="post">
    <input type="text" name="name" placeholder="名前を入力" required>
    <!-- ここに、年齢を入力するための新しい箱を追加したぞ -->
    <input type="number" name="age" placeholder="年齢">
    <button type="submit">追加</button>
  </form>
</body>
</html>

